{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "extensionsToTreatAsEsm": [],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", {
      "useESM": false,
      "tsconfig": "tsconfig.test.json"
    }]
  },
  "testMatch": ["**/tests/**/*.test.ts"],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 70,
      "lines": 70
    }
  }
}
